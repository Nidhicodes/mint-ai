---
import '../styles/global.css';

interface Props {
  title?: string;
  description?: string;
}

const { title = 'Mint AI', description = 'Your personal AI app store. Describe what you want. Get a working app.' } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#09090b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="manifest" href="/manifest.json" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="min-h-screen overflow-x-hidden">
    <!-- Ambient glow -->
    <div class="fixed inset-0 -z-10 pointer-events-none" aria-hidden="true">
      <div class="absolute top-[-20%] left-[-10%] w-[500px] h-[500px] rounded-full bg-mint-500/[0.03] blur-[120px] animate-float"></div>
      <div class="absolute bottom-[-15%] right-[-10%] w-[400px] h-[400px] rounded-full bg-mint-400/[0.02] blur-[100px] animate-float" style="animation-delay: 3s"></div>
    </div>
    <slot />
  </body>
</html>
