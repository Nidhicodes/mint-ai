---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Mint AI — Describe any app. Get it instantly." description="Your personal creative universe. Describe any app you want and get it instantly. 100% local, zero cost, infinite apps.">
  <main class="min-h-screen flex flex-col">

    <!-- Navigation -->
    <nav class="fixed top-0 left-0 right-0 z-50 bg-zinc-950/80 backdrop-blur-md border-b border-zinc-800/50">
      <div class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
        <div class="flex items-center gap-2">
          <svg class="w-5 h-5 text-mint-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89-.82L7 21l-1-3.5C9.5 13 14 9 17 8z"/><path d="M17 8c-4 1-7 4-8.5 7.5"/></svg>
          <span class="text-lg font-semibold text-zinc-100 tracking-tight">Mint AI</span>
        </div>
        <a
          href="/app"
          class="text-sm font-medium text-zinc-400 hover:text-zinc-100 link-underline px-3 py-1.5"
        >
          Open App
        </a>
      </div>
    </nav>

    <!-- Hero Section -->
    <section class="relative flex flex-col items-center justify-center text-center px-6 pt-32 pb-16 overflow-hidden">
      <h1 class="text-6xl sm:text-7xl md:text-8xl font-bold tracking-tight text-zinc-100 mb-4 animate-fade-in relative">
        <span class="text-gradient">Mint AI</span>
      </h1>
      <p class="text-lg sm:text-xl text-zinc-400 max-w-md mb-10 animate-fade-in leading-relaxed" style="animation-delay: 0.1s">
        Describe any app. Get it instantly.
      </p>

      <!-- The Prompt Bar -->
      <div class="w-full max-w-2xl mx-auto animate-fade-in" style="animation-delay: 0.2s">
        <form id="hero-prompt-form" class="relative">
          <div class="glass rounded-2xl border border-zinc-800 shadow-lg focus-within:border-mint-400 focus-within:shadow-xl transition-all duration-300">
            <div class="flex items-center gap-3 px-5 py-4">
              <input
                id="hero-prompt-input"
                type="text"
                class="flex-1 bg-transparent text-lg text-zinc-100 placeholder-gray-400 outline-none"
                placeholder="A pomodoro timer with ambient sounds..."
                autocomplete="off"
              />
              <button
                type="submit"
                class="bg-gray-900 hover:bg-mint-600 text-white font-medium text-sm px-6 py-2.5 rounded-full transition-all duration-200 shrink-0"
              >
                Create
                <span class="ml-1" aria-hidden="true">&rarr;</span>
              </button>
            </div>
          </div>
        </form>
        <p class="text-center text-xs text-zinc-500 mt-4">
          No server. No API key. No cost. Runs in your browser.
        </p>
      </div>
    </section>

    <!-- Live Showcase -->
    <section class="px-6 py-20 max-w-6xl mx-auto w-full">
      <div class="text-center mb-12 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold text-zinc-100 mb-4 tracking-tight">
          See what people are building
        </h2>
        <p class="text-zinc-400 max-w-lg mx-auto leading-relaxed">
          Real apps, running live. Every one was generated from a single prompt.
        </p>
      </div>

      <div id="showcase-grid" class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6 reveal-stagger">
        <!-- Gallery apps injected by script -->
      </div>
    </section>

    <!-- How It Works -->
    <section class="px-6 py-20 max-w-5xl mx-auto w-full">
      <div class="text-center mb-14 reveal">
        <h2 class="text-3xl sm:text-4xl font-bold text-zinc-100 mb-4 tracking-tight">
          How it works
        </h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 reveal-stagger">
        <!-- Step 1: Describe -->
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-mint-50 border border-mint-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-mint-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
              <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-100 mb-2">Describe what you want</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Type a plain-language description of the app you have in mind.
          </p>
        </div>

        <!-- Step 2: Generate -->
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-mint-50 border border-mint-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-mint-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M12 2l2.4 7.4H22l-6.2 4.5 2.4 7.4L12 16.8l-6.2 4.5 2.4-7.4L2 9.4h7.6z"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-100 mb-2">AI generates it instantly</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            AI writes the code and builds a complete, working app in seconds.
          </p>
        </div>

        <!-- Step 3: Use & Share -->
        <div class="text-center">
          <div class="w-14 h-14 mx-auto mb-5 rounded-2xl bg-mint-50 border border-mint-100 flex items-center justify-center">
            <svg class="w-6 h-6 text-mint-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/>
              <path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/>
              <path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/>
              <path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-zinc-100 mb-2">Use, modify, and share</h3>
          <p class="text-sm text-zinc-400 leading-relaxed">
            Iterate with follow-up prompts. Export, fork, or share with anyone.
          </p>
        </div>
      </div>
    </section>

    <!-- Bold Differentiator -->
    <section class="px-6 py-20 reveal">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl sm:text-4xl font-bold text-zinc-100 mb-10 tracking-tight">
          100% local. Zero cost. Infinite apps.
        </h2>
        <div class="flex flex-col sm:flex-row items-center justify-center gap-8 sm:gap-16">
          <div>
            <p class="text-4xl font-bold text-mint-400">100%</p>
            <p class="text-sm text-zinc-400 mt-1">Runs on your device</p>
          </div>
          <div class="hidden sm:block w-px h-12 bg-gray-200" aria-hidden="true"></div>
          <div>
            <p class="text-4xl font-bold text-mint-400">$0</p>
            <p class="text-sm text-zinc-400 mt-1">Free with browser AI</p>
          </div>
          <div class="hidden sm:block w-px h-12 bg-gray-200" aria-hidden="true"></div>
          <div>
            <p class="text-4xl font-bold text-mint-400">&infin;</p>
            <p class="text-sm text-zinc-400 mt-1">Create as many as you want</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Footer CTA -->
    <section class="px-6 py-20 text-center reveal">
      <p class="text-zinc-500 text-sm mb-8">No sign-up required. Start building in seconds.</p>
      <a
        href="/app"
        class="inline-flex items-center gap-2.5 px-8 py-4 rounded-full text-base font-semibold
               bg-mint-500 text-black hover:bg-mint-600
               shadow-lg shadow-mint-500/10
               hover:shadow-xl hover:shadow-mint-500/20 hover:scale-[1.03]
               transition-all duration-300"
      >
        Open Mint AI
        <span class="text-black/60" aria-hidden="true">&rarr;</span>
      </a>
    </section>

    <!-- Footer -->
    <footer class="px-6 py-8 border-t border-zinc-800/40">
      <div class="max-w-5xl mx-auto flex items-center justify-between">
        <div class="flex items-center gap-2 text-zinc-500 text-sm">
          <svg class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89-.82L7 21l-1-3.5C9.5 13 14 9 17 8z"/><path d="M17 8c-4 1-7 4-8.5 7.5"/></svg>
          <span>Mint AI</span>
        </div>
        <p class="text-xs text-zinc-500">Built for your browser. Runs on your device.</p>
      </div>
    </footer>
  </main>

  <!-- Landing page scripts -->
  <script>
    // --- Shared app detection via URL hash ---
    (function detectSharedApp() {
      const hash = window.location.hash;
      if (hash && hash.startsWith('#app=')) {
        // Redirect to the share page, preserving the hash
        window.location.replace('/share' + hash);
        return;
      }
    })();

    // --- Rotating placeholder text ---
    const placeholders = [
      'A pomodoro timer with ambient sounds...',
      'A budget tracker with pie charts...',
      'A flashcard app for studying...',
      'A workout log with body diagram...',
      'A recipe scaler for cooking...',
    ];
    let placeholderIndex = 0;
    const input = document.getElementById('hero-prompt-input') as HTMLInputElement;

    function rotatePlaceholder() {
      if (!input || document.activeElement === input) return;
      placeholderIndex = (placeholderIndex + 1) % placeholders.length;
      input.style.transition = 'opacity 0.3s ease';
      input.style.opacity = '0';
      setTimeout(() => {
        input.placeholder = placeholders[placeholderIndex];
        input.style.opacity = '1';
      }, 300);
    }
    setInterval(rotatePlaceholder, 4000);

    // --- Prompt form submission ---
    const form = document.getElementById('hero-prompt-form');
    form?.addEventListener('submit', (e) => {
      e.preventDefault();
      const value = input?.value.trim();
      if (value) {
        window.location.href = '/app?prompt=' + encodeURIComponent(value);
      }
    });

    // --- Load gallery apps into showcase ---
    async function loadShowcase() {
      try {
        const res = await fetch('/gallery.json');
        const data = await res.json();
        const apps = data.apps.slice(0, 6);
        const grid = document.getElementById('showcase-grid');
        if (!grid) return;

        apps.forEach((app: any) => {
          const card = document.createElement('div');
          card.className = 'glass rounded-2xl overflow-hidden glass hover:border-zinc-700 transition-all duration-300 group';

          const blob = new Blob([app.html], { type: 'text/html' });
          const blobUrl = URL.createObjectURL(blob);

          card.innerHTML = `
            <div class="relative w-full h-[300px] bg-gray-50 overflow-hidden">
              <iframe
                src="${blobUrl}"
                sandbox="allow-scripts allow-same-origin"
                class="w-full h-full border-0 pointer-events-none"
                title="${app.title} preview"
                loading="lazy"
              ></iframe>
            </div>
            <div class="p-4">
              <h3 class="font-semibold text-zinc-100 mb-1">${app.title}</h3>
              <p class="text-sm text-zinc-400 line-clamp-2 mb-3">${app.description}</p>
              <div class="flex items-center justify-between">
                <div class="flex gap-1.5">
                  ${app.tags.slice(0, 3).map((tag: string) => `<span class="text-[10px] px-2 py-0.5 rounded-full bg-mint-50 text-mint-700">${tag}</span>`).join('')}
                </div>
                <a href="/app?fork=${app.id}" class="text-xs text-mint-400 hover:text-mint-700 px-3 py-1.5 rounded-lg hover:bg-mint-50 transition-all font-medium">Fork</a>
              </div>
            </div>
          `;
          grid.appendChild(card);
        });
      } catch (e) {
        // Gallery load is best-effort
      }
    }
    loadShowcase();

    // --- Scroll-triggered reveal ---
    if (typeof IntersectionObserver !== 'undefined') {
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add('revealed');
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: '0px 0px -40px 0px' }
      );
      document.querySelectorAll('.reveal, .reveal-stagger').forEach((el) => {
        observer.observe(el);
      });
    }
  </script>
</Layout>
