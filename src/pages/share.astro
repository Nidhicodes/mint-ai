---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Shared App — Mint AI">
  <div id="share-container" class="min-h-screen">
    <!-- Loading state -->
    <div id="share-loading" class="flex flex-col items-center justify-center min-h-screen">
      <svg class="w-8 h-8 text-mint-500 animate-pulse mb-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89-.82L7 21l-1-3.5C9.5 13 14 9 17 8z"/><path d="M17 8c-4 1-7 4-8.5 7.5"/></svg>
      <p class="text-sm text-gray-500">Loading shared app...</p>
    </div>

    <!-- Error state (hidden by default) -->
    <div id="share-error" style="display:none" class="flex flex-col items-center justify-center min-h-screen text-center px-4">
      <div class="w-12 h-12 rounded-full bg-red-50 flex items-center justify-center mb-4">
        <svg class="w-6 h-6 text-red-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
      </div>
      <h1 class="font-serif text-xl font-semibold text-gray-900 mb-2">Invalid or expired share link</h1>
      <p class="text-sm text-gray-500 mb-6">This link doesn't contain a valid app, or the data could not be decoded.</p>
      <a href="/app" class="text-sm text-mint-600 hover:text-mint-700 font-medium px-4 py-2 rounded-lg hover:bg-mint-50 transition-all">
        &larr; Go to Mint AI
      </a>
    </div>

    <!-- App display (hidden by default) -->
    <div id="share-app" style="display:none" class="h-screen flex flex-col">
      <!-- Full-screen iframe -->
      <iframe
        id="share-iframe"
        sandbox="allow-scripts allow-same-origin allow-modals allow-forms"
        class="flex-1 w-full bg-white border-0"
        title="Shared app preview"
      ></iframe>
      <!-- Bottom banner -->
      <div id="share-banner" class="flex items-center justify-between px-5 py-3 bg-white border-t border-gray-200/50 shrink-0">
        <div class="flex items-center gap-2">
          <svg class="w-4 h-4 text-mint-500" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 8C8 10 5.9 16.17 3.82 21.34l1.89-.82L7 21l-1-3.5C9.5 13 14 9 17 8z"/><path d="M17 8c-4 1-7 4-8.5 7.5"/></svg>
          <span class="text-sm text-gray-500">Made with <a href="/" class="text-mint-600 hover:text-mint-700 font-medium">Mint AI</a></span>
        </div>
        <button
          id="fork-btn"
          class="text-sm font-medium text-mint-600 hover:text-mint-700 px-4 py-1.5 rounded-lg hover:bg-mint-50 transition-all border border-mint-200 hover:border-mint-300"
        >
          Fork to my library
        </button>
      </div>
    </div>
  </div>

  <script>
    import { decodeApp } from '../lib/sharing/encode';

    function init() {
      const loadingEl = document.getElementById('share-loading')!;
      const errorEl = document.getElementById('share-error')!;
      const appEl = document.getElementById('share-app')!;
      const iframe = document.getElementById('share-iframe') as HTMLIFrameElement;
      const forkBtn = document.getElementById('fork-btn')!;

      try {
        const hash = window.location.hash;
        if (!hash || !hash.startsWith('#app=')) {
          throw new Error('No app data in URL');
        }

        const encoded = hash.slice(5); // Remove '#app='
        if (!encoded) {
          throw new Error('Empty app data');
        }

        const html = decodeApp(encoded);
        if (!html || !html.trim()) {
          throw new Error('Decoded HTML is empty');
        }

        // Show the app
        loadingEl.style.display = 'none';
        appEl.style.display = 'flex';
        iframe.srcdoc = html;

        // Fork button: redirect to /app with the compressed data
        forkBtn.addEventListener('click', () => {
          window.location.href = '/app?fork_html=' + encodeURIComponent(encoded);
        });
      } catch {
        // Show error state
        loadingEl.style.display = 'none';
        errorEl.style.display = 'flex';
      }
    }

    init();
  </script>
</Layout>
