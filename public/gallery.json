    {
      "id": "gallery-fitness-log",
      "title": "Fitness Log",
      "description": "Log exercises by muscle group with a simple SVG body outline highlighting worked muscles.",
      "tags": ["health", "fitness"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Fitness Log</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff;padding:20px;display:flex;flex-direction:column;align-items:center;gap:16px}h1{font-size:1.3rem;color:#22c55e}.form{display:flex;gap:6px;flex-wrap:wrap;justify-content:center}select,input{padding:8px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#fff;font-size:.85rem}button{padding:8px 14px;border:none;border-radius:8px;background:#22c55e;color:#000;cursor:pointer;font-size:.85rem}button:hover{background:#16a34a}.body-wrap{position:relative;width:160px;height:320px}svg text{font-size:8px;fill:#888}.muscle{transition:fill .3s}.active{fill:#22c55e !important}#log{width:100%;max-width:400px}.entry{display:flex;justify-content:space-between;padding:6px 10px;background:#161616;border-radius:6px;margin-bottom:4px;font-size:.8rem}.del{background:none;border:none;color:#444;cursor:pointer}.del:hover{color:#e94560}</style></head><body><h1>💪 Fitness Log</h1><div class=\"form\"><select id=\"mg\"><option>Chest</option><option>Back</option><option>Shoulders</option><option>Arms</option><option>Core</option><option>Legs</option></select><input id=\"ex\" placeholder=\"Exercise name\"><input id=\"sets\" type=\"number\" placeholder=\"Sets\" min=\"1\" style=\"width:60px\"><button onclick=\"add()\">Log</button></div><div class=\"body-wrap\"><svg viewBox=\"0 0 160 320\" width=\"160\" height=\"320\"><ellipse cx=\"80\" cy=\"30\" rx=\"18\" ry=\"22\" fill=\"#333\" class=\"muscle\" id=\"m-head\"/><rect x=\"60\" y=\"52\" width=\"40\" height=\"10\" rx=\"4\" fill=\"#333\" class=\"muscle\" id=\"m-shoulders\"/><rect x=\"65\" y=\"62\" width=\"30\" height=\"45\" rx=\"6\" fill=\"#333\" class=\"muscle\" id=\"m-chest\"/><rect x=\"50\" y=\"62\" width=\"14\" height=\"40\" rx=\"5\" fill=\"#333\" class=\"muscle\" id=\"m-arms-l\"/><rect x=\"96\" y=\"62\" width=\"14\" height=\"40\" rx=\"5\" fill=\"#333\" class=\"muscle\" id=\"m-arms-r\"/><rect x=\"68\" y=\"107\" width=\"24\" height=\"30\" rx=\"4\" fill=\"#333\" class=\"muscle\" id=\"m-core\"/><rect x=\"65\" y=\"137\" width=\"13\" height=\"55\" rx=\"5\" fill=\"#333\" class=\"muscle\" id=\"m-legs-l\"/><rect x=\"82\" y=\"137\" width=\"13\" height=\"55\" rx=\"5\" fill=\"#333\" class=\"muscle\" id=\"m-legs-r\"/><rect x=\"63\" y=\"195\" width=\"14\" height=\"50\" rx=\"4\" fill=\"#333\" class=\"muscle\" id=\"m-calves-l\"/><rect x=\"83\" y=\"195\" width=\"14\" height=\"50\" rx=\"4\" fill=\"#333\" class=\"muscle\" id=\"m-calves-r\"/></svg></div><div id=\"log\"></div><script>const K='fit-data',map={Chest:['m-chest'],Back:['m-chest'],Shoulders:['m-shoulders'],Arms:['m-arms-l','m-arms-r'],Core:['m-core'],Legs:['m-legs-l','m-legs-r','m-calves-l','m-calves-r']};function load(){try{return JSON.parse(localStorage.getItem(K))||[]}catch{return[]}}function save(d){localStorage.setItem(K,JSON.stringify(d))}function add(){const mg=document.getElementById('mg').value,ex=document.getElementById('ex').value.trim(),sets=document.getElementById('sets').value;if(!ex)return;const d=load();d.push({mg,ex,sets:+sets||1,date:new Date().toISOString().slice(0,10)});save(d);document.getElementById('ex').value='';render()}function del(i){const d=load();d.splice(i,1);save(d);render()}function render(){const d=load(),log=document.getElementById('log'),today=new Date().toISOString().slice(0,10);log.innerHTML='';document.querySelectorAll('.muscle').forEach(m=>m.classList.remove('active'));const todayLogs=d.filter(e=>e.date===today);const worked=new Set();todayLogs.forEach(e=>{(map[e.mg]||[]).forEach(id=>worked.add(id))});worked.forEach(id=>{const el=document.getElementById(id);if(el)el.classList.add('active')});d.slice(-20).reverse().forEach((e,i)=>{log.innerHTML+=`<div class=\"entry\"><span>${e.ex} · ${e.mg} · ${e.sets}s</span><button class=\"del\" onclick=\"del(${d.length-1-i})\">✕</button></div>`})}render()</script></body></html>",
