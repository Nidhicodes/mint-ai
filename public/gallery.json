    {
      "id": "gallery-dice",
      "title": "Dice Roller",
      "description": "Roll up to 6 dice with satisfying animations. Great for board games.",
      "tags": ["fun", "utility"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Dice</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#1a1a2e;font-family:system-ui;display:flex;flex-direction:column;align-items:center;justify-content:center;color:#fff;gap:24px}h1{font-size:1.3rem}#dice{display:flex;gap:12px;flex-wrap:wrap;justify-content:center}.die{width:64px;height:64px;background:#16213e;border-radius:12px;display:flex;align-items:center;justify-content:center;font-size:2rem;border:2px solid #0f3460;transition:transform .3s}.die.roll{animation:shake .4s}.ctrls{display:flex;gap:12px;align-items:center}label{font-size:.9rem}select{padding:6px 12px;border-radius:8px;background:#16213e;color:#fff;border:1px solid #0f3460}button{padding:10px 28px;border:none;border-radius:8px;background:#e94560;color:#fff;font-size:1rem;cursor:pointer}button:hover{background:#c81e45}#total{font-size:1.2rem;color:#e94560}@keyframes shake{0%,100%{transform:rotate(0)}25%{transform:rotate(-15deg)}75%{transform:rotate(15deg)}}</style></head><body><h1>🎲 Dice Roller</h1><div id=\"dice\"></div><div id=\"total\"></div><div class=\"ctrls\"><label>Count:</label><select id=\"cnt\"><option>1</option><option selected>2</option><option>3</option><option>4</option><option>5</option><option>6</option></select><button onclick=\"roll()\">Roll</button></div><script>const faces=['⚀','⚁','⚂','⚃','⚄','⚅'];function roll(){const n=+document.getElementById('cnt').value,d=document.getElementById('dice');d.innerHTML='';let sum=0;for(let i=0;i<n;i++){const v=Math.floor(Math.random()*6);sum+=v+1;const el=document.createElement('div');el.className='die roll';el.textContent=faces[v];d.appendChild(el)}document.getElementById('total').textContent='Total: '+sum}roll()</script></body></html>",
