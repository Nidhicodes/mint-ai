    {
      "id": "gallery-color-palette",
      "title": "Color Palette Generator",
      "description": "Generate random color palettes with hex codes. Click any swatch to copy.",
      "tags": ["creative", "design"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Palette</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#111;font-family:system-ui;display:flex;flex-direction:column;align-items:center;padding:24px;color:#fff}h1{margin-bottom:16px;font-size:1.4rem}#palette{display:flex;gap:12px;flex-wrap:wrap;justify-content:center;margin-bottom:20px}.swatch{width:100px;height:140px;border-radius:12px;cursor:pointer;display:flex;align-items:flex-end;justify-content:center;padding:8px;font-size:.75rem;font-family:monospace;transition:transform .2s}.swatch:hover{transform:scale(1.05)}button{background:#22c55e;color:#000;border:none;padding:10px 24px;border-radius:8px;font-size:1rem;cursor:pointer}button:hover{background:#16a34a}#msg{margin-top:12px;font-size:.85rem;color:#22c55e;min-height:20px}</style></head><body><h1>🎨 Color Palette</h1><div id=\"palette\"></div><button onclick=\"gen()\">Generate</button><div id=\"msg\"></div><script>function rh(){return '#'+Math.floor(Math.random()*16777215).toString(16).padStart(6,'0')}function lum(h){const r=parseInt(h.slice(1,3),16),g=parseInt(h.slice(3,5),16),b=parseInt(h.slice(5,7),16);return(0.299*r+0.587*g+0.114*b)/255}function gen(){const p=document.getElementById('palette');p.innerHTML='';for(let i=0;i<5;i++){const c=rh(),s=document.createElement('div');s.className='swatch';s.style.background=c;s.style.color=lum(c)>0.5?'#000':'#fff';s.textContent=c;s.onclick=()=>{navigator.clipboard.writeText(c);document.getElementById('msg').textContent='Copied '+c};p.appendChild(s)}}gen()</script></body></html>",
