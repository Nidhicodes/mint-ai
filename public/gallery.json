    {
      "id": "gallery-habit-tracker",
      "title": "Habit Tracker",
      "description": "Add habits, check off daily completions, and track current and longest streaks.",
      "tags": ["health", "productivity"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Habit Tracker</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff;padding:20px;max-width:500px;margin:0 auto}h1{font-size:1.3rem;margin-bottom:16px;color:#22c55e}.bar{display:flex;gap:8px;margin-bottom:16px}input{flex:1;padding:10px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#fff;font-size:.85rem}button{padding:10px 16px;border:none;border-radius:8px;background:#22c55e;color:#000;cursor:pointer;font-size:.85rem}button:hover{background:#16a34a}.habit{background:#161616;border:1px solid #222;border-radius:12px;padding:12px 16px;margin-bottom:8px;display:flex;align-items:center;justify-content:space-between}.left{display:flex;align-items:center;gap:10px}.check{width:28px;height:28px;border-radius:8px;border:2px solid #333;display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:.9rem;transition:all .2s}.check.done{background:#22c55e;border-color:#22c55e;color:#000}.name{font-size:.95rem}.streak{font-size:.75rem;color:#888;text-align:right}.streak b{color:#f59e0b}.del{background:none;border:none;color:#333;cursor:pointer;font-size:1rem;margin-left:8px}.del:hover{color:#e94560}</style></head><body><h1>✅ Habit Tracker</h1><div class=\"bar\"><input id=\"inp\" placeholder=\"New habit...\" onkeydown=\"event.key==='Enter'&&add()\"><button onclick=\"add()\">Add</button></div><div id=\"list\"></div><script>const K='habit-data';function today(){return new Date().toISOString().slice(0,10)}function load(){try{return JSON.parse(localStorage.getItem(K))||[]}catch{return[]}}function save(d){localStorage.setItem(K,JSON.stringify(d))}function streak(h){const ds=h.days||[];if(!ds.length)return{cur:0,max:0};let cur=0,max=0,s=0;const sorted=[...new Set(ds)].sort().reverse();const t=today();if(sorted[0]===t||sorted[0]===yest()){for(let i=0;i<sorted.length-1;i++){const d1=new Date(sorted[i]),d2=new Date(sorted[i+1]);if((d1-d2)/(864e5)===1)cur++;else break}cur++}max=cur;let run=1;for(let i=0;i<sorted.length-1;i++){const d1=new Date(sorted[i]),d2=new Date(sorted[i+1]);if((d1-d2)/(864e5)===1)run++;else run=1;if(run>max)max=run}return{cur,max}}function yest(){const d=new Date();d.setDate(d.getDate()-1);return d.toISOString().slice(0,10)}function add(){const v=document.getElementById('inp').value.trim();if(!v)return;const d=load();d.push({name:v,days:[]});save(d);document.getElementById('inp').value='';render()}function toggle(i){const d=load(),t=today(),idx=d[i].days.indexOf(t);if(idx>=0)d[i].days.splice(idx,1);else d[i].days.push(t);save(d);render()}function del(i){const d=load();d.splice(i,1);save(d);render()}function render(){const d=load(),list=document.getElementById('list'),t=today();list.innerHTML='';d.forEach((h,i)=>{const done=h.days&&h.days.includes(t),s=streak(h);list.innerHTML+=`<div class=\"habit\"><div class=\"left\"><div class=\"check ${done?'done':''}\" onclick=\"toggle(${i})\">${done?'✓':''}</div><span class=\"name\">${h.name}</span></div><div class=\"streak\">🔥 <b>${s.cur}</b> day${s.cur!==1?'s':''} · Best: ${s.max}<button class=\"del\" onclick=\"del(${i})\">✕</button></div></div>`})}render()</script></body></html>",
