    {
      "id": "gallery-pomodoro-heatmap",
      "title": "Pomodoro Heatmap",
      "description": "25/5 minute pomodoro timer with a weekly heatmap grid showing completed sessions per day.",
      "tags": ["productivity", "health"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Pomodoro Heatmap</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff;display:flex;flex-direction:column;align-items:center;justify-content:center;gap:20px;padding:20px}h1{font-size:1.3rem}#timer{font-size:3.5rem;font-variant-numeric:tabular-nums;color:#22c55e}.btns{display:flex;gap:8px}button{padding:10px 20px;border:none;border-radius:8px;cursor:pointer;font-size:.9rem;background:#222;color:#fff}button:hover{background:#333}button.go{background:#22c55e;color:#000}button.go:hover{background:#16a34a}#mode{font-size:.85rem;color:#888}.heatmap{display:grid;grid-template-columns:repeat(7,36px);gap:4px}.cell{width:36px;height:36px;border-radius:6px;display:flex;flex-direction:column;align-items:center;justify-content:center;font-size:.6rem;color:#aaa;background:#161616}.cell.l1{background:#14532d}.cell.l2{background:#166534}.cell.l3{background:#16a34a}.cell.l4{background:#22c55e}.days{display:grid;grid-template-columns:repeat(7,36px);gap:4px;margin-bottom:2px}.days span{text-align:center;font-size:.6rem;color:#555}</style></head><body><h1>🍅 Pomodoro</h1><div id=\"timer\">25:00</div><div id=\"mode\">Work Session</div><div class=\"btns\"><button class=\"go\" onclick=\"toggle()\">Start</button><button onclick=\"reset()\">Reset</button></div><div class=\"days\"><span>Mon</span><span>Tue</span><span>Wed</span><span>Thu</span><span>Fri</span><span>Sat</span><span>Sun</span></div><div class=\"heatmap\" id=\"hm\"></div><script>let sec=1500,run=false,iv,isWork=true;const K='pomo-data';function load(){try{return JSON.parse(localStorage.getItem(K))||{}}catch{return{}}}function save(d){localStorage.setItem(K,JSON.stringify(d))}function fmt(s){const m=Math.floor(s/60),r=s%60;return(m<10?'0':'')+m+':'+(r<10?'0':'')+r}function tick(){if(sec<=0){clearInterval(iv);run=false;if(isWork){const d=load(),k=new Date().toISOString().slice(0,10);d[k]=(d[k]||0)+1;save(d)}isWork=!isWork;sec=isWork?1500:300;document.getElementById('mode').textContent=isWork?'Work Session':'Break';render()}sec--;document.getElementById('timer').textContent=fmt(sec)}function toggle(){if(run){clearInterval(iv);run=false}else{iv=setInterval(tick,1000);run=true}}function reset(){clearInterval(iv);run=false;isWork=true;sec=1500;document.getElementById('timer').textContent='25:00';document.getElementById('mode').textContent='Work Session'}function render(){const d=load(),hm=document.getElementById('hm');hm.innerHTML='';const now=new Date(),dow=((now.getDay()+6)%7);for(let i=6;i>=0;i--){const dt=new Date(now);dt.setDate(dt.getDate()-(dow-i+(dow<i?7:0)));const k=dt.toISOString().slice(0,10),v=d[k]||0;const c=document.createElement('div');c.className='cell'+(v>=4?' l4':v>=3?' l3':v>=2?' l2':v>=1?' l1':'');c.innerHTML=dt.getDate()+'<span>'+(v||'')+'</span>';hm.appendChild(c)}}render()</script></body></html>",
