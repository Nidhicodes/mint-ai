    {
      "id": "gallery-portfolio-tracker",
      "title": "Portfolio Tracker",
      "description": "Add stock symbols with quantities, view mock prices and total portfolio value.",
      "tags": ["finance", "utility"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Portfolio Tracker</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff;padding:20px;max-width:500px;margin:0 auto}h1{font-size:1.3rem;margin-bottom:16px;color:#22c55e}.form{display:flex;gap:6px;margin-bottom:16px}input{padding:8px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#fff;font-size:.85rem}input.sym{width:90px;text-transform:uppercase}input.qty{width:70px}button{padding:8px 14px;border:none;border-radius:8px;background:#22c55e;color:#000;cursor:pointer;font-size:.85rem}button:hover{background:#16a34a}#total{text-align:center;font-size:1.5rem;color:#22c55e;margin:16px 0;padding:16px;background:#161616;border-radius:12px;border:1px solid #222}table{width:100%;border-collapse:collapse}th{text-align:left;font-size:.75rem;color:#555;padding:8px 4px;border-bottom:1px solid #222}td{padding:8px 4px;font-size:.85rem;border-bottom:1px solid #161616}.up{color:#22c55e}.dn{color:#e94560}.del{background:none;border:none;color:#444;cursor:pointer}.del:hover{color:#e94560}</style></head><body><h1>📈 Portfolio Tracker</h1><div class=\"form\"><input class=\"sym\" id=\"sym\" placeholder=\"AAPL\"><input class=\"qty\" id=\"qty\" type=\"number\" placeholder=\"Qty\" min=\"1\"><button onclick=\"add()\">Add</button></div><div id=\"total\">$0.00</div><table><thead><tr><th>Symbol</th><th>Qty</th><th>Price</th><th>Value</th><th>Chg</th><th></th></tr></thead><tbody id=\"tb\"></tbody></table><script>const K='port-data',prices={AAPL:189.50,GOOGL:141.80,MSFT:378.90,AMZN:178.25,TSLA:248.50,META:485.60,NVDA:875.30,NFLX:628.40,AMD:155.20,INTC:31.40};function mock(s){return prices[s.toUpperCase()]||(50+Math.random()*200)}function chg(){return(Math.random()*6-3)}function load(){try{return JSON.parse(localStorage.getItem(K))||[]}catch{return[]}}function save(d){localStorage.setItem(K,JSON.stringify(d))}function add(){const s=document.getElementById('sym').value.trim().toUpperCase(),q=parseInt(document.getElementById('qty').value);if(!s||!q||q<1)return;const d=load(),ex=d.find(x=>x.sym===s);if(ex)ex.qty+=q;else d.push({sym:s,qty:q});save(d);document.getElementById('sym').value='';document.getElementById('qty').value='';render()}function del(i){const d=load();d.splice(i,1);save(d);render()}function render(){const d=load(),tb=document.getElementById('tb');let tot=0;tb.innerHTML='';d.forEach((h,i)=>{const p=mock(h.sym),v=p*h.qty,c=chg();tot+=v;tb.innerHTML+=`<tr><td><b>${h.sym}</b></td><td>${h.qty}</td><td>$${p.toFixed(2)}</td><td>$${v.toFixed(2)}</td><td class=\"${c>=0?'up':'dn'}\">${c>=0?'+':''}${c.toFixed(2)}%</td><td><button class=\"del\" onclick=\"del(${i})\">✕</button></td></tr>`});document.getElementById('total').textContent='Total: $'+tot.toFixed(2)}render()</script></body></html>",
