    {
      "id": "gallery-expense-tracker",
      "title": "Expense Tracker",
      "description": "Add expenses by category and see a pie chart breakdown using the Canvas API.",
      "tags": ["finance", "productivity"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Expense Tracker</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff;padding:20px;max-width:500px;margin:0 auto}h1{font-size:1.3rem;margin-bottom:16px;color:#22c55e}.form{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap}input,select{padding:8px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#fff;font-size:.85rem}input[type=number]{width:90px}select{flex:1}button{padding:8px 16px;border:none;border-radius:8px;background:#22c55e;color:#000;cursor:pointer;font-size:.85rem}button:hover{background:#16a34a}canvas{display:block;margin:16px auto}#list{margin-top:12px}.item{display:flex;justify-content:space-between;padding:8px 12px;background:#161616;border-radius:8px;margin-bottom:4px;font-size:.85rem}.item .cat{color:#888}.del{background:none;border:none;color:#555;cursor:pointer}.del:hover{color:#e94560}#total{text-align:center;font-size:1.1rem;color:#22c55e;margin:12px 0}</style></head><body><h1>💰 Expense Tracker</h1><div class=\"form\"><input type=\"number\" id=\"amt\" placeholder=\"Amount\" min=\"0\" step=\"0.01\"><select id=\"cat\"><option>Food</option><option>Transport</option><option>Shopping</option><option>Bills</option><option>Entertainment</option><option>Other</option></select><button onclick=\"add()\">Add</button></div><canvas id=\"chart\" width=\"200\" height=\"200\"></canvas><div id=\"total\"></div><div id=\"list\"></div><script>const K='exp-data',colors=['#e94560','#f59e0b','#3b82f6','#8b5cf6','#22c55e','#ec4899'];function load(){try{return JSON.parse(localStorage.getItem(K))||[]}catch{return[]}}function save(d){localStorage.setItem(K,JSON.stringify(d))}function add(){const a=parseFloat(document.getElementById('amt').value);if(!a||a<=0)return;const c=document.getElementById('cat').value;const d=load();d.push({amount:a,category:c,date:Date.now()});save(d);document.getElementById('amt').value='';render()}function del(i){const d=load();d.splice(i,1);save(d);render()}function render(){const d=load(),list=document.getElementById('list');list.innerHTML='';let t=0;const cats={};d.forEach((e,i)=>{t+=e.amount;cats[e.category]=(cats[e.category]||0)+e.amount;list.innerHTML+=`<div class=\"item\"><span>$${e.amount.toFixed(2)} <span class=\"cat\">${e.category}</span></span><button class=\"del\" onclick=\"del(${i})\">✕</button></div>`});document.getElementById('total').textContent='Total: $'+t.toFixed(2);const cv=document.getElementById('chart'),ctx=cv.getContext('2d');ctx.clearRect(0,0,200,200);const entries=Object.entries(cats),catList=['Food','Transport','Shopping','Bills','Entertainment','Other'];if(t>0){let a=-Math.PI/2;entries.forEach(([c,v])=>{const s=v/t*Math.PI*2;ctx.beginPath();ctx.moveTo(100,100);ctx.arc(100,100,90,a,a+s);ctx.fillStyle=colors[catList.indexOf(c)%6];ctx.fill();a+=s})}}render()</script></body></html>",
      "thumbnailUrl": "",
      "featured": false,
      "createdAt": 1719158400000
    },
    {
      "id": "gallery-flashcard-engine",
      "title": "Flashcard Engine",
      "description": "Create decks of flashcards, flip to reveal answers, mark known/unknown, and track progress.",
      "tags": ["education", "productivity"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Flashcard Engine</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff;display:flex;flex-direction:column;align-items:center;padding:24px;gap:16px}h1{font-size:1.3rem;color:#22c55e}.add{display:flex;gap:6px;flex-wrap:wrap;justify-content:center}input{padding:8px 12px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#fff;font-size:.85rem;width:160px}button{padding:8px 16px;border:none;border-radius:8px;cursor:pointer;font-size:.85rem;background:#222;color:#fff}button:hover{background:#333}button.pri{background:#22c55e;color:#000}button.pri:hover{background:#16a34a}.card{width:300px;min-height:180px;background:#161616;border:1px solid #222;border-radius:16px;display:flex;align-items:center;justify-content:center;text-align:center;padding:24px;font-size:1.1rem;cursor:pointer;transition:transform .3s;user-select:none}.card:hover{transform:scale(1.02)}.card.flipped{background:#1a2e1a;border-color:#22c55e33}.acts{display:flex;gap:8px}#prog{font-size:.85rem;color:#888}#info{font-size:.75rem;color:#555}</style></head><body><h1>🃏 Flashcards</h1><div class=\"add\"><input id=\"q\" placeholder=\"Question\"><input id=\"a\" placeholder=\"Answer\"><button class=\"pri\" onclick=\"addCard()\">Add</button></div><div id=\"prog\"></div><div class=\"card\" id=\"card\" onclick=\"flip()\">Add cards to begin</div><div class=\"acts\"><button onclick=\"mark(false)\">❌ Don't Know</button><button class=\"pri\" onclick=\"mark(true)\">✅ Know</button></div><div id=\"info\"></div><script>const K='fc-data';function load(){try{return JSON.parse(localStorage.getItem(K))||[]}catch{return[]}}function save(d){localStorage.setItem(K,JSON.stringify(d))}let cards=load(),idx=0,flipped=false;function addCard(){const q=document.getElementById('q').value.trim(),a=document.getElementById('a').value.trim();if(!q||!a)return;cards.push({q,a,known:false});save(cards);document.getElementById('q').value='';document.getElementById('a').value='';show()}function flip(){if(!cards.length)return;flipped=!flipped;const c=document.getElementById('card');c.textContent=flipped?cards[idx].a:cards[idx].q;c.className=flipped?'card flipped':'card'}function mark(known){if(!cards.length)return;cards[idx].known=known;save(cards);idx=(idx+1)%cards.length;flipped=false;show()}function show(){const c=document.getElementById('card');if(!cards.length){c.textContent='Add cards to begin';c.className='card';document.getElementById('prog').textContent='';return}c.textContent=cards[idx].q;c.className='card';const known=cards.filter(c=>c.known).length;document.getElementById('prog').textContent=`${known}/${cards.length} known (${Math.round(known/cards.length*100)}%)`;document.getElementById('info').textContent=`Card ${idx+1} of ${cards.length}`}show()</script></body></html>",
