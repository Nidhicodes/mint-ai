    {
      "id": "gallery-notes",
      "title": "Quick Notes",
      "description": "A minimal note-taking app with localStorage persistence and markdown-style formatting.",
      "tags": ["productivity", "utility"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Notes</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0f0f0f;font-family:system-ui;color:#fff;padding:20px;max-width:600px;margin:0 auto}h1{font-size:1.3rem;margin-bottom:16px;color:#22c55e}.bar{display:flex;gap:8px;margin-bottom:16px}input{flex:1;padding:10px;border-radius:8px;border:1px solid #333;background:#1a1a1a;color:#fff;font-size:.9rem}button{padding:10px 16px;border:none;border-radius:8px;background:#22c55e;color:#000;cursor:pointer;font-size:.9rem}button:hover{background:#16a34a}.note{background:#1a1a1a;border:1px solid #222;border-radius:8px;padding:12px;margin-bottom:8px;display:flex;justify-content:space-between;align-items:start}.note p{flex:1;white-space:pre-wrap;word-break:break-word}.del{background:none;border:none;color:#666;cursor:pointer;font-size:1.1rem;padding:0 0 0 8px}.del:hover{color:#e94560}</style></head><body><h1>📝 Quick Notes</h1><div class=\"bar\"><input id=\"inp\" placeholder=\"Write a note...\" onkeydown=\"event.key==='Enter'&&add()\"><button onclick=\"add()\">Add</button></div><div id=\"list\"></div><script>let notes=JSON.parse(localStorage.getItem('qn')||'[]');function save(){localStorage.setItem('qn',JSON.stringify(notes))}function render(){const l=document.getElementById('list');l.innerHTML='';notes.forEach((n,i)=>{const d=document.createElement('div');d.className='note';d.innerHTML=`<p>${n.replace(/</g,'&lt;')}</p><button class=\"del\" onclick=\"del(${i})\">✕</button>`;l.appendChild(d)})}function add(){const v=document.getElementById('inp').value.trim();if(!v)return;notes.unshift(v);save();render();document.getElementById('inp').value=''}function del(i){notes.splice(i,1);save();render()}render()</script></body></html>",
