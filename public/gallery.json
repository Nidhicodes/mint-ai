    {
      "id": "gallery-markdown-slides",
      "title": "Markdown Slides",
      "description": "Type markdown, split by ---, and present as slides with arrow key navigation.",
      "tags": ["creative", "productivity"],
      "author": "Mint AI",
      "html": "<!DOCTYPE html><html><head><meta charset=\"utf-8\"><meta name=\"viewport\" content=\"width=device-width,initial-scale=1\"><title>Markdown Slides</title><style>*{margin:0;padding:0;box-sizing:border-box}body{min-height:100vh;background:#0a0a0a;font-family:system-ui;color:#fff}.edit{display:flex;flex-direction:column;height:100vh;padding:16px}.top{display:flex;justify-content:space-between;align-items:center;margin-bottom:12px}h1{font-size:1.1rem;color:#22c55e}button{padding:8px 20px;border:none;border-radius:8px;background:#22c55e;color:#000;cursor:pointer;font-size:.85rem}button:hover{background:#16a34a}textarea{flex:1;background:#161616;border:1px solid #222;border-radius:12px;padding:16px;color:#fff;font-family:monospace;font-size:.9rem;resize:none;outline:none}textarea:focus{border-color:#22c55e33}.present{display:none;height:100vh;flex-direction:column;align-items:center;justify-content:center;padding:40px;text-align:center}.slide{max-width:700px;width:100%}.slide h1,.slide h2,.slide h3{margin-bottom:16px;color:#22c55e}.slide p{margin-bottom:12px;line-height:1.6;color:#ccc}.slide ul,.slide ol{text-align:left;margin:0 auto 12px;max-width:500px;color:#ccc}.slide li{margin-bottom:6px}.slide code{background:#222;padding:2px 6px;border-radius:4px;font-size:.85rem}.nav{position:fixed;bottom:20px;display:flex;gap:12px;align-items:center}.nav button{background:#222;color:#fff;padding:8px 16px}.nav button:hover{background:#333}#counter{font-size:.75rem;color:#555}.hint{font-size:.7rem;color:#444;margin-top:8px}</style></head><body><div class=\"edit\" id=\"editor\"><div class=\"top\"><h1>📽 Markdown Slides</h1><button onclick=\"present()\">Present</button></div><textarea id=\"md\"># Welcome to Slides\n\nType your markdown here.\nSeparate slides with ---\n\n---\n\n# Slide 2\n\n- Bullet points work\n- Arrow keys to navigate\n- Press Escape to edit</textarea><p class=\"hint\">Separate slides with --- on its own line</p></div><div class=\"present\" id=\"pres\"><div class=\"slide\" id=\"slide\"></div><div class=\"nav\"><button onclick=\"prev()\">← Prev</button><span id=\"counter\">1/1</span><button onclick=\"next()\">Next →</button></div></div><script>let slides=[],cur=0;function md2html(s){return s.replace(/^### (.+)$/gm,'<h3>$1</h3>').replace(/^## (.+)$/gm,'<h2>$1</h2>').replace(/^# (.+)$/gm,'<h1>$1</h1>').replace(/\\*\\*(.+?)\\*\\*/g,'<b>$1</b>').replace(/\\*(.+?)\\*/g,'<i>$1</i>').replace(/`([^`]+)`/g,'<code>$1</code>').replace(/^- (.+)$/gm,'<li>$1</li>').replace(/(<li>.*<\\/li>)/gs,'<ul>$1</ul>').replace(/\\n\\n/g,'</p><p>').replace(/^(?!<[hluob])/gm,function(m){return m?'<p>'+m:m})}function present(){const t=document.getElementById('md').value;slides=t.split(/\\n---\\n/).map(s=>s.trim());cur=0;document.getElementById('editor').style.display='none';document.getElementById('pres').style.display='flex';show()}function show(){document.getElementById('slide').innerHTML=md2html(slides[cur]);document.getElementById('counter').textContent=(cur+1)+'/'+slides.length}function next(){if(cur<slides.length-1){cur++;show()}}function prev(){if(cur>0){cur--;show()}}document.addEventListener('keydown',e=>{if(e.key==='ArrowRight')next();if(e.key==='ArrowLeft')prev();if(e.key==='Escape'){document.getElementById('editor').style.display='flex';document.getElementById('pres').style.display='none'}})</script></body></html>",
      "thumbnailUrl": "",
      "featured": false,
      "createdAt": 1718726400000
    }
  ]
